# Ticketmaster Discovery API
# Crie sua key gratuita em: https://developer.ticketmaster.com
TICKETMASTER_API_KEY=sua_api_key_aqui

# Telegram Bot
# Crie um bot pelo @BotFather no Telegram e cole o token abaixo
TELEGRAM_BOT_TOKEN=seu_bot_token_aqui

# Chat ID do Telegram (seu ID pessoal ou de um grupo)
# Para obter seu chat ID: envie uma mensagem para @userinfobot no Telegram
TELEGRAM_CHAT_ID=seu_chat_id_aqui
